{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openagentprotocol.eu/schemas/v1.0/oap-receipt.schema.json",
  "title": "OAP Receipt",
  "type": "object",
  "required": ["receipt_id", "type", "timestamp", "principal_did", "agent_did", "previous_receipt_hash", "signatures"],
  "additionalProperties": false,
  "properties": {
    "receipt_id": { "type": "string", "pattern": "^urn:oap:receipt:.+$" },
    "type": { "enum": ["invocation", "subscription", "settlement", "consent", "deletion", "incident", "kill_switch", "procurement_offer", "procurement_acceptance", "delivery_proof", "citation_attribution", "task_completion", "irreversible_pending", "irreversible_withdrawn", "escalation_response"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "principal_did": { "type": "string" },
    "agent_did": { "type": "string" },
    "tool_did": { "type": "string" },
    "action_id": { "type": "string" },
    "action_version": { "type": "string" },
    "input_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "output_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "model_version": { "type": "string" },
    "cost": {
      "type": "object",
      "properties": {
        "amount": { "type": "string" },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
      }
    },
    "policy_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "outcome"],
        "properties": {
          "id": { "type": "string" },
          "outcome": { "enum": ["allow", "allow_with_conditions", "require_consent", "require_anonymization", "block"] },
          "rules": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "provenance_tags_in": { "type": "array", "items": { "type": "string" } },
    "provenance_tags_out": { "type": "array", "items": { "type": "string" } },
    "consumption_proof": {
      "type": "object",
      "description": "Per Token Knowledge Commerce consumption proof per RFC 0013 § 3.5. Present for receipts that meter content delivery.",
      "required": ["unit", "count", "content_hash"],
      "properties": {
        "knowledge_node_ids": { "type": "array", "items": { "type": "string" } },
        "unit": { "enum": ["token", "byte", "knowledge_node", "citation"] },
        "count": { "type": "integer", "minimum": 0 },
        "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "metering_mechanism": { "enum": ["volume", "watermark", "embedding_attribution", "zero_knowledge"], "description": "Mechanism per RFC 0013 § 3.9." },
        "price_per_unit": { "type": "string", "pattern": "^\\d+(?:\\.\\d+)?$" },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
      }
    },
    "citations": {
      "type": "array",
      "description": "Citation Attribution Receipts per RFC 0013 § 3.5. Present when an agent's output incorporates content from one or more Knowledge Providers.",
      "items": {
        "type": "object",
        "required": ["provider_did", "knowledge_node_id"],
        "properties": {
          "provider_did": { "type": "string" },
          "knowledge_node_id": { "type": "string" },
          "contribution_weight": { "type": "number", "minimum": 0, "maximum": 1 },
          "output_segment_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        }
      }
    },
    "commerce_primitive": { "$ref": "https://openagentprotocol.eu/schemas/v1.0/oap-commerce-primitive.schema.json", "description": "Self describing record of which Commerce Primitive applied at settlement, per RFC 0014 \u00a7 5.4." },    "irreversibility": {
      "type": "object",
      "description": "Per RFC 0017. Present on irreversible_pending, irreversible_withdrawn, and on final receipts that follow a Pending Receipt.",
      "properties": {
        "irreversibility_class": { "enum": ["legal_status_change", "bodily_intervention", "immovable_property", "irreversible_financial", "public_disclosure"] },
        "cooling_off_deadline": { "type": "string", "format": "date-time" },
        "withdrawal_endpoint": { "type": "string", "format": "uri" },
        "pending_receipt_id": { "type": "string", "pattern": "^urn:oap:receipt:.+$" },
        "consequence_statement_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "emergency_declaration_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "escalation": {
      "type": "object",
      "description": "Per RFC 0018. Present on escalation_response receipts.",
      "properties": {
        "case_id": { "type": "string" },
        "operator_identifier": { "type": "string" },
        "channel": { "enum": ["voice", "video", "text_chat", "email", "physical"] },
        "duration_seconds": { "type": "integer", "minimum": 0 },
        "transcript_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "zkp": {
      "type": "object",
      "description": "Zero-Knowledge State Proof (e.g., zk-SNARK) replacing input/output hashes for GDPR Art. 17 compliance.",
      "required": ["system", "public_inputs", "proof"],
      "properties": {
        "system": { "enum": ["groth16", "plonk", "stark"] },
        "curve": { "type": "string" },
        "public_inputs": { "type": "array", "items": { "type": "string" } },
        "proof": { "type": "object", "additionalProperties": true }
      }
    },
    "previous_receipt_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$|^genesis$" },
    "anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "log_id": { "type": "string" },
          "log_index": { "type": "integer" },
          "inclusion_proof": { "type": "string" }
        }
      }
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["by", "alg", "value"],
        "properties": {
          "by": { "type": "string" },
          "alg": { "enum": ["EdDSA", "ES256", "ES384"] },
          "value": { "type": "string" }
        }
      }
    }
  }
}
