{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openagentprotocol.eu/schemas/v1.0/oap-convention-drift-receipt.schema.json",
  "title": "OAP Convention Drift Receipt",
  "description": "RFC 0027 section 3.4b. Emitted when an Agent's Tier 2 posterior over a peer's type diverges from observed empirical action distribution beyond drift_threshold_kl, triggering re-inference.",
  "type": "object",
  "required": [
    "receipt_id",
    "type",
    "timestamp",
    "agent_did",
    "context",
    "affected_peer_did",
    "kl_divergence",
    "drift_threshold_kl",
    "decision",
    "signatures"
  ],
  "additionalProperties": false,
  "properties": {
    "receipt_id": {
      "type": "string",
      "pattern": "^urn:oap:receipt:.+$"
    },
    "type": {
      "const": "convention_drift"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "agent_did": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:.+$"
    },
    "context": {
      "type": "object",
      "required": [
        "context_type",
        "context_id"
      ],
      "properties": {
        "context_type": {
          "enum": [
            "workflow",
            "session"
          ]
        },
        "context_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "affected_peer_did": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:.+$"
    },
    "kl_divergence": {
      "type": "number",
      "minimum": 0
    },
    "drift_threshold_kl": {
      "type": "number",
      "minimum": 0
    },
    "observation_window_size": {
      "type": "integer",
      "minimum": 1
    },
    "prior_posterior_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "reset_prior_ref": {
      "type": "string",
      "description": "Reference to the recency-decayed mixture prior used to reset the Tier 2 posterior."
    },
    "decision": {
      "enum": [
        "re-infer",
        "abort"
      ]
    },
    "previous_receipt_hash": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "const": "genesis"
        },
        {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      ],
      "description": "sha256 of canonicalized previous Receipt; \"genesis\" for chain root; null when not in a chain."
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "signer_did",
          "signature"
        ],
        "properties": {
          "signer_did": {
            "type": "string",
            "pattern": "^did:[a-z0-9]+:.+$"
          },
          "signature": {
            "type": "string",
            "minLength": 1
          },
          "alg": {
            "enum": [
              "Ed25519",
              "ES256K",
              "ES256"
            ]
          }
        }
      }
    }
  }
}