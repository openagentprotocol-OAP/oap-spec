{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openagentprotocol.eu/schemas/v1.0/oap-manifest.schema.json",
  "title": "OAP Tool Manifest",
  "description": "Normative schema for an Open Agent Protocol Tool Manifest, version 1.0.",
  "type": "object",
  "required": [
    "oap_version",
    "tool",
    "endpoints",
    "auth",
    "actions",
    "sla",
    "trust",
    "data_policy",
    "risk_class",
    "jurisdictions",
    "governance"
  ],
  "additionalProperties": false,
  "properties": {
    "oap_version": {
      "type": "string",
      "const": "1.0"
    },
    "tool": {
      "type": "object",
      "required": ["id", "did", "name", "version", "publisher", "categories", "description_for_humans", "description_for_agents"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}[a-z0-9]$" },
        "did": { "type": "string", "pattern": "^did:[a-z0-9]+:.+$" },
        "name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+].+)?$" },
        "publisher": {
          "type": "object",
          "required": ["did", "legal_name", "verified"],
          "additionalProperties": false,
          "properties": {
            "did": { "type": "string", "pattern": "^did:[a-z0-9]+:.+$" },
            "legal_name": { "type": "string" },
            "registry": {
              "type": "object",
              "required": ["type", "id", "country"],
              "properties": {
                "type": { "type": "string" },
                "id": { "type": "string" },
                "country": { "type": "string", "pattern": "^[A-Z]{2}$" }
              }
            },
            "verified": { "type": "boolean" }
          }
        },
        "categories": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "icon": { "type": "string", "format": "uri" },
        "description_for_humans": { "type": "string", "minLength": 1, "maxLength": 4000 },
        "description_for_agents": { "type": "string", "minLength": 1, "maxLength": 4000 }
      }
    },
    "endpoints": {
      "type": "object",
      "required": ["invoke", "audit", "data_delete", "incident"],
      "additionalProperties": false,
      "properties": {
        "invoke":      { "type": "string", "format": "uri" },
        "stream":      { "type": "string", "format": "uri" },
        "subscribe":   { "type": "string", "format": "uri" },
        "billing":     { "type": "string", "format": "uri" },
        "audit":       { "type": "string", "format": "uri" },
        "data_export": { "type": "string", "format": "uri" },
        "data_delete": { "type": "string", "format": "uri" },
        "consent":     { "type": "string", "format": "uri" },
        "incident":    { "type": "string", "format": "uri" },
        "discover":    { "type": "string", "format": "uri" }
      }
    },
    "auth": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["method"],
        "properties": {
          "method": { "enum": ["anonymous", "api_key", "oauth2_1", "oap_trust_token", "mtls"] },
          "config": { "type": "object" }
        }
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "https://openagentprotocol.eu/schemas/v1.0/oap-action.schema.json" }
    },
    "consequential_provider": {
      "type": "boolean",
      "description": "Per RFC 0018 \u00a7 3. True if any Action affects legal, financial, medical, familial, or otherwise consequential status of a person. Requires the 'escalate_to_human' Action and the escalation_service_level block."
    },
    "conformance": {
      "type": "object",
      "description": "Per RFC 0019 \u00a7 4. Self attested or independently witnessed conformance claims. Consuming Agents SHOULD verify these claims through the procedure in RFC 0019 \u00a7 6 before engaging the Provider for Consequential Actions.",
      "properties": {
        "claimed_levels": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(L[0-5]|W[1-3]|C[1-3])$" },
          "description": "Conformance Levels the Provider claims to satisfy. Each claimed level MUST be evidenced by the linked Conformance Receipt."
        },
        "receipt_uri": {
          "type": "string",
          "format": "uri",
          "description": "Public URL of the signed Conformance Receipt that evidences the claimed_levels. The Receipt MUST conform to oap-conformance-receipt.schema.json."
        },
        "suite_version": { "type": "string", "description": "Version of the OAP Conformance Test Suite under which the receipt was issued." },
        "last_attested_at": { "type": "string", "format": "date-time" },
        "next_attestation_due": { "type": "string", "format": "date-time" },
        "attestor": {
          "type": "object",
          "properties": {
            "did": { "type": "string" },
            "method": { "type": "string", "enum": ["self", "third_party_replay", "live_witness", "registry"] }
          }
        }
      }
    },
    "escalation_service_level": {
      "type": "object",
      "description": "Service Level for the Escalation Action per RFC 0018 \u00a7 4.3. REQUIRED when consequential_provider is true.",
      "properties": {
        "response_seconds_by_urgency": {
          "type": "object",
          "properties": {
            "low": { "type": "integer", "minimum": 0 },
            "normal": { "type": "integer", "minimum": 0 },
            "high": { "type": "integer", "minimum": 0 },
            "critical": { "type": "integer", "minimum": 0 }
          }
        },
        "channels": {
          "type": "array",
          "items": { "enum": ["voice", "video", "text_chat", "email", "physical"] },
          "minItems": 1
        },
        "working_hours": { "type": "string", "description": "ISO 8601 timezone aware description of working hours, e.g. 'Mon-Fri 09:00-18:00 Europe/Berlin'." },
        "out_of_hours_fallback_channel": { "enum": ["voice", "video", "text_chat", "email", "physical"] },
        "performance_report_uri": { "type": "string", "format": "uri" }
      }
    },
    "commerce": {
      "type": "object",
      "description": "Top level commerce declaration per RFC 0013. Capabilities MAY override individual fields at the action level via the action's cost block.",
      "properties": {
        "default_model": { "enum": ["per_invocation", "per_outcome", "per_token_knowledge", "per_capability", "per_delegation"] },
        "settlement_window_days": { "type": "integer", "minimum": 1, "maximum": 365, "description": "Billing window for Settlement Statements per RFC 0013 \u00a7 3.5 and \u00a7 3.10." },
        "reconciliation_log": {
          "type": "object",
          "description": "Reference to the OAP Reconciliation Log entry per RFC 0013 \u00a7 3.10. REQUIRED at conformance level C3.",
          "properties": {
            "endpoint": { "type": "string", "format": "uri" },
            "anchor_cadence": { "enum": ["weekly", "monthly", "quarterly", "annually"] }
          }
        },
        "match_broker": {
          "type": "object",
          "description": "If this Origin acts as a Match Broker per RFC 0013 \u00a7 3.4, the methodology disclosure MUST be linked here.",
          "properties": {
            "is_broker": { "type": "boolean" },
            "ranking_methodology_uri": { "type": "string", "format": "uri" },
            "broker_fee_per_match": { "type": "string", "pattern": "^\\d+(?:\\.\\d+)?$" },
            "broker_fee_currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
          }
        },
        "knowledge_metering": {
          "type": "object",
          "description": "Knowledge metering capabilities per RFC 0013 \u00a7 3.9. The 'volume' mechanism is REQUIRED for any Origin that prices content per_token_knowledge.",
          "properties": {
            "mechanisms": {
              "type": "array",
              "items": { "enum": ["volume", "watermark", "embedding_attribution", "zero_knowledge"] },
              "minItems": 1
            },
            "embedding_catalog_uri": { "type": "string", "format": "uri" },
            "audit_endpoint": { "type": "string", "format": "uri" }
          }        },
        "primitives": {
          "type": "array",
          "description": "Commerce Primitives per RFC 0014. Each entry is a five axis description of an offered commerce model. Providers MAY mix any number of primitives.",
          "items": { "$ref": "https://openagentprotocol.eu/schemas/v1.0/oap-commerce-primitive.schema.json" }        }
      }
    },
    "pricing": {
      "type": "object",
      "required": ["models"],
      "properties": {
        "free_tier": { "type": "object" },
        "models": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {
                "type": "object",
                "required": ["type"],
                "properties": { "type": { "const": "free" } }
              },
              {
                "type": "object",
                "required": ["type", "amount", "currency"],
                "properties": {
                  "type": { "const": "per_call" },
                  "amount": { "type": "string", "pattern": "^\\d+(?:\\.\\d+)?$" },
                  "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
                }
              },
              {
                "type": "object",
                "required": ["type", "tiers"],
                "properties": {
                  "type": { "const": "subscription" },
                  "tiers": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["id", "amount", "currency", "interval"],
                      "properties": {
                        "id": { "type": "string" },
                        "amount": { "type": "string", "pattern": "^\\d+(?:\\.\\d+)?$" },
                        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
                        "interval": { "enum": ["day", "week", "month", "year"] }
                      }
                    }
                  }
                }
              },
              {
                "type": "object",
                "required": ["type", "unit", "amount_per_1000", "currency"],
                "properties": {
                  "type": { "const": "usage_metered" },
                  "unit": { "type": "string" },
                  "amount_per_1000": { "type": "string" },
                  "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
                }
              },
              {
                "type": "object",
                "required": ["type", "trigger", "amount", "currency"],
                "properties": {
                  "type": { "const": "outcome" },
                  "trigger": { "type": "string" },
                  "amount": { "type": "string" },
                  "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
                }
              }
            ]
          }
        }
      }
    },
    "sla": {
      "type": "object",
      "required": ["uptime_target", "latency_p95_ms", "max_call_duration_ms", "regions", "incident_disclosure_within_hours"],
      "properties": {
        "uptime_target": { "type": "number", "minimum": 0, "maximum": 1 },
        "latency_p95_ms": { "type": "integer", "minimum": 0 },
        "latency_p99_ms": { "type": "integer", "minimum": 0 },
        "max_call_duration_ms": { "type": "integer", "minimum": 0 },
        "supports_streaming": { "type": "boolean" },
        "supports_async": { "type": "boolean" },
        "regions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "max_concurrency_per_principal": { "type": "integer", "minimum": 1 },
        "incident_disclosure_within_hours": { "type": "integer", "minimum": 1, "maximum": 168 },
        "scheduled_maintenance_notice_hours": { "type": "integer", "minimum": 0 }
      }
    },
    "trust": {
      "type": "object",
      "required": ["publisher_verified", "data_residency", "gdpr_compliant"],
      "properties": {
        "publisher_verified": { "type": "boolean" },
        "code_audited": { "type": "array", "items": { "type": "object" } },
        "data_residency": { "type": "array", "items": { "type": "string" } },
        "gdpr_compliant": { "type": "boolean" },
        "soc2_type_ii": { "type": "boolean" },
        "iso_27001": { "type": "boolean" },
        "open_source": { "type": ["string", "null"], "format": "uri" },
        "trust_score": { "type": ["number", "null"] },
        "user_reviews": { "type": ["integer", "null"] },
        "incidents_last_90d": { "type": "integer", "minimum": 0 }
      }
    },
    "data_policy": {
      "type": "object",
      "required": ["stores_principal_data", "retention_days", "shares_with_third_parties", "training_on_principal_data", "deletion_endpoint", "lawful_bases"],
      "properties": {
        "stores_principal_data": { "type": "boolean" },
        "retention_days": { "type": "integer", "minimum": 0 },
        "shares_with_third_parties": { "type": "boolean" },
        "third_parties": { "type": "array", "items": { "type": "string" } },
        "training_on_principal_data": { "enum": ["never", "with_consent", "by_default"] },
        "deletion_endpoint": { "type": "string" },
        "export_endpoint": { "type": "string" },
        "lawful_bases": {
          "type": "array",
          "items": { "enum": ["consent", "contract", "legal_obligation", "vital_interests", "public_task", "legitimate_interests"] }
        },
        "special_categories_handled": { "type": "array", "items": { "type": "string" } },
        "international_transfers": { "type": "array", "items": { "type": "object" } },
        "subprocessors_url": { "type": "string", "format": "uri" }
      }
    },
    "collaboration": {
      "type": "object",
      "properties": {
        "supports_concurrent_agents": { "type": "boolean" },
        "locking_strategy": { "enum": ["optimistic", "pessimistic", "crdt"] },
        "conflict_resolution_endpoint": { "type": "string" },
        "broadcast_changes": { "type": "boolean" },
        "change_subscription": { "type": "string" }
      }
    },
    "sessions": {
      "type": "object",
      "description": "OPTIONAL extension proposed in RFC 0001 (Coordination Sessions). Declares support for multi turn collaborative sessions with shared state.",
      "properties": {
        "supported": { "type": "boolean" },
        "max_participants": { "type": "integer", "minimum": 2 },
        "max_duration_hours": { "type": "integer", "minimum": 1 },
        "state_schema": { "type": "string", "format": "uri" },
        "concurrency_model": { "enum": ["optimistic", "pessimistic", "crdt"] },
        "resumable_after_disconnect": { "type": "boolean" },
        "supports_pause": { "type": "boolean" },
        "supports_handoff": { "type": "boolean" }
      }
    },
    "negotiation": {
      "type": "object",
      "description": "OPTIONAL extension proposed in RFC 0002 (Negotiation Protocol). Declares support for structured multi round bargaining.",
      "properties": {
        "supported": { "type": "boolean" },
        "categories": {
          "type": "array",
          "items": { "enum": ["pricing", "scheduling", "scope", "sla", "terms"] }
        },
        "max_rounds": { "type": "integer", "minimum": 1 },
        "default_validity_minutes": { "type": "integer", "minimum": 1 },
        "binding_acceptance": { "type": "boolean" },
        "withdrawal_penalty_terms": { "type": "string", "format": "uri" }
      }
    },
    "standing_permissions": {
      "type": "object",
      "description": "OPTIONAL extension proposed in RFC 0003 (Standing Permissions). Declares support for pre authorized recurring invocations.",
      "properties": {
        "supported": { "type": "boolean" },
        "max_grants_per_principal": { "type": "integer", "minimum": 1 },
        "max_grant_duration_days": { "type": "integer", "minimum": 1, "maximum": 365 },
        "minimum_revocation_check_interval_seconds": { "type": "integer", "minimum": 60 },
        "supports_push_revocation": { "type": "boolean" }
      }
    },
    "delegation": {
      "type": "object",
      "description": "OPTIONAL extension proposed in RFC 0004 (Sub Agent Delegation). Declares support for parent and sub agent invocation trees with cost attribution.",
      "properties": {
        "supported": { "type": "boolean" },
        "max_concurrent_sub_agents_per_parent": { "type": "integer", "minimum": 1 },
        "max_delegation_depth": { "type": "integer", "minimum": 1, "maximum": 5 },
        "supports_aggregation_receipt": { "type": "boolean" },
        "billing_modes": {
          "type": "array",
          "items": { "enum": ["parent", "sub_agent"] }
        },
        "sub_tree_bucket_enforcement": {
          "type": "boolean",
          "description": "RFC 0011: Tool aggregates rate limits, budgets, and reputation across the entire Delegation Tree as one Actor."
        },
        "requires_anti_sybil_proof": {
          "type": "array",
          "description": "RFC 0011: Anti Sybil Proof types accepted at sub agent spawn time.",
          "items": { "enum": ["VerifiedPrincipal", "DelegationStake", "VerifiableComputation"] }
        },
        "minimum_delegation_stake_eur": {
          "type": "string",
          "description": "RFC 0011: Refundable stake the parent must commit when DelegationStake proof is required."
        },
        "coordinated_behavior_threshold": {
          "type": "number",
          "description": "RFC 0011: Coordinated Behavior Score above which the Tool refuses, throttles, or labels invocations.",
          "minimum": 0,
          "maximum": 1
        },
        "restricted_actions_policy": {
          "type": "string",
          "description": "RFC 0011: Policy applied to Restricted Actions (reputation issuance, marketplace voting, negotiation bids, governance polls).",
          "enum": ["platform_default", "stricter", "by_explicit_grant_only"]
        }
      }
    },
    "canonical_entities": {
      "type": "object",
      "description": "OPTIONAL extension proposed in RFC 0005 (Canonical Entity Schemas). Declares which oap.entity.* types the Tool natively supports.",
      "properties": {
        "supported": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "versions", "modes"],
            "properties": {
              "type": { "type": "string", "pattern": "^oap\\.entity\\.[a-z_]+$" },
              "versions": { "type": "array", "items": { "type": "string" } },
              "modes": {
                "type": "array",
                "items": { "enum": ["read", "write", "search", "merge"] }
              }
            }
          }
        },
        "translation_endpoint": { "type": "string", "format": "uri" }
      }
    },
    "personas": {
      "type": "object",
      "description": "OPTIONAL extension proposed in RFC 0006 (Persona and Scope Layer). Declares support for multiple bounded identities per Principal with industry profiles.",
      "properties": {
        "supported": { "type": "boolean" },
        "max_scopes_per_principal": { "type": "integer", "minimum": 1 },
        "supports_industry_profiles": {
          "type": "array",
          "items": { "type": "string", "pattern": "^oap\\.profile\\.[a-z_]+\\.[a-z_]+$" }
        },
        "scope_inheritance_for_sub_agents": { "enum": ["always", "explicit", "never"] }
      }
    },
    "projections": {
      "type": "object",
      "description": "OPTIONAL extension proposed in RFC 0007 (Privacy Preserving Projections). Declares support for trust level dependent partial entity disclosure.",
      "properties": {
        "supported": { "type": "boolean" },
        "default_trust_level_for_unknown_did": { "type": "integer", "minimum": 0, "maximum": 4 },
        "supported_profiles": {
          "type": "array",
          "items": { "type": "string", "pattern": "^oap\\.profile\\.projection\\." }
        },
        "trust_evidence_accepted": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "workflows": {
      "type": "object",
      "description": "OPTIONAL extension proposed in RFC 0008 (Workflow Composition). Declares support for multi step Action compositions discoverable by intent.",
      "properties": {
        "supported": { "type": "boolean" },
        "registry_url": { "type": "string", "format": "uri" },
        "workflows_published": {
          "type": "array",
          "items": { "type": "string", "pattern": "^oap\\.workflow\\." }
        }
      }
    },
    "reputation": {
      "type": "object",
      "description": "OPTIONAL extension proposed in RFC 0009 (Reputation and Performance Records). Declares portable reputation publication and dispute endpoints.",
      "properties": {
        "publishes_records": { "type": "boolean" },
        "accepts_records_about_self": { "type": "boolean" },
        "response_endpoint": { "type": "string", "format": "uri" },
        "dispute_endpoint": { "type": "string", "format": "uri" }
      }
    },
    "memory_exchange": {
      "type": "object",
      "description": "OPTIONAL extension proposed in RFC 0010 (Memory Exchange Protocol). Declares support for granted, scoped exchange of agent memory items between Agents.",
      "properties": {
        "supported": { "type": "boolean" },
        "max_grant_duration_days": { "type": "integer", "minimum": 1, "maximum": 365 },
        "max_grant_size_items": { "type": "integer", "minimum": 1 },
        "supported_redaction_profiles": {
          "type": "array",
          "items": { "type": "string", "pattern": "^oap\\.profile\\.projection\\." }
        }
      }
    },
    "risk_class": { "enum": ["minimal", "limited", "high"] },
    "jurisdictions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[A-Z]{2}$" }
    },
    "insurance": {
      "type": "object",
      "properties": {
        "carrier_did": { "type": "string" },
        "policy_id": { "type": "string" },
        "coverage_eur": { "type": "string" },
        "covered_perils": { "type": "array", "items": { "type": "string" } },
        "valid_until": { "type": "string", "format": "date" },
        "credential": { "type": "string" }
      }
    },
    "governance": {
      "type": "object",
      "required": ["dispute_resolution_url", "contact_email"],
      "properties": {
        "dispute_resolution_url": { "type": "string", "format": "uri" },
        "contact_email": { "type": "string", "format": "email" },
        "revocation_status_url": { "type": "string", "format": "uri" }
      }
    },
    "ad_hoc_teamwork": {
      "type": "object",
      "description": "RFC 0027 Ad Hoc Teamwork declaration. When convention_discovery_v2 is true, aht_fallback_policy is required (RFC 0027 section 3.5).",
      "additionalProperties": false,
      "required": ["supported"],
      "properties": {
        "supported": { "type": "boolean" },
        "capability_announcement_v1": { "type": "boolean" },
        "late_join_modes": {
          "type": "array",
          "items": { "enum": ["convener_gated", "capability_match", "open"] },
          "uniqueItems": true
        },
        "convention_discovery_v1": { "type": "boolean" },
        "convention_discovery_v2": { "type": "boolean" },
        "max_capabilities_per_announcement": { "type": "integer", "minimum": 1, "maximum": 1024 },
        "unilateral_timeout_ms": { "type": "integer", "minimum": 100, "maximum": 60000 },
        "convention_inference_v1": { "type": "boolean" },
        "regret_tolerance": { "type": "number", "minimum": 0, "maximum": 1 },
        "drift_threshold_kl": { "type": "number", "minimum": 0 },
        "max_byzantine_fraction": { "type": "number", "minimum": 0, "maximum": 0.333333 },
        "aht_fallback_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["policy_class", "assumptions"],
          "properties": {
            "policy_class": { "enum": ["POAM", "PLASTIC", "AATEAM", "ROTATE", "Custom"] },
            "policy_ref": { "type": "string", "format": "uri" },
            "assumptions": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            },
            "training_distribution_ref": { "type": "string", "format": "uri" }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "convention_discovery_v2": { "const": true } }, "required": ["convention_discovery_v2"] },
          "then": { "required": ["aht_fallback_policy", "unilateral_timeout_ms"] }
        }
      ]
    }
  }
}
