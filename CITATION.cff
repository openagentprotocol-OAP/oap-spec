preferred-citation:
  type: report
  title: "Open Agent Protocol, Version 1.0 Public Working Draft"
  authors:
    - name: "Open Agent Protocol Working Groups"
  year: 2026
  month: 5
  institution:
    name: "Open Agent Protocol Stewards"
  number: "OAP-CORE-1.0"
  url: "https://openagentprotocol.eu/spec"
  abstract: >-
    The normative specification of the Open Agent Protocol, including the
    Manifest, Request Envelope, Response Envelope, Receipt, Decision Record,
    Audit Log, Agent Query Language, Verifiable Index, Manifest Subscription
    Protocol, and the four layer Policy Stack. The document references 24
    Request for Comments documents and 10 supporting whitepapers.
